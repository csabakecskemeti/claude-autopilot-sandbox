# LLM Backend (LM Studio, Ollama, vLLM, litellm, etc.)
#
# IMPORTANT: Use the ACTUAL hostname/IP of your LLM server
# - If on same Mac: localhost or 127.0.0.1
# - If on LAN: Use mDNS hostname (e.g., spark-db71.local) or IP (e.g., 192.168.7.103)
#
# macOS Tunnels (AUTOMATIC):
# On macOS, Docker containers cannot reach LAN devices directly.
# run.sh automatically detects LAN hosts and creates socat tunnels.
# You don't need to configure anything - just use the real hostname!
#
# Examples:
#   LLM_HOST=192.168.1.100      (LAN IP - tunnel auto-created)
#   LLM_HOST=spark-db71.local   (mDNS - tunnel auto-created)
#   LLM_HOST=localhost          (same Mac - no tunnel needed)
#
# Manual tunnel management:
#   make tunnel           - Start tunnels based on .env
#   make tunnel-status    - Show running tunnels
#   make tunnel-stop      - Stop all tunnels
#   make install-socat    - Install socat (required for tunnels)
#
# For litellm/vllm proxies, use ANTHROPIC_AUTH_TOKEN (not ANTHROPIC_API_KEY)
LLM_HOST=<your-llm-hostname-or-ip>
LLM_PORT=11234
LLM_AUTH_TOKEN=lmstudio
LLM_MODEL=<your-model-name>

# Vision Model (optional - for screenshot/image analysis)
# Uses same host/port as LLM backend by default
VISION_MODEL=qwen/qwen3-vl-4b

# Web Search (SearXNG)
# Self-hosted meta-search engine - run with: make searxng-start
# Agent container connects via host.docker.internal by default
# SEARXNG_URL=http://host.docker.internal:8888

# Resource Limits
MEMORY_LIMIT=16G
MEMORY_RESERVATION=2G

# Workspace
WORKSPACE_NAME=default
# Base path for workspaces (use internal drive on macOS to avoid exFAT issues)
# Leave commented to use ./workspaces/ relative to project
# WORKSPACE_BASE=/Users/yourusername/claude-workspaces

# Shared Folder (Read-Only Access)
# Mount a local folder into worker and supervisor containers at /shared (read-only)
# Useful for giving agent access to reference files, datasets, or codebases without write access
# SHARE=/path/to/your/folder

# Langfuse Tracing (optional - for agent evaluation)
# Get keys from your Langfuse instance Settings → API Keys
# TRACE_TO_LANGFUSE=true
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_SECRET_KEY=sk-lf-xxx
# LANGFUSE_HOST=http://host.docker.internal:3000
# LANGFUSE_PROJECT=claude-code
# LANGFUSE_DEBUG=false

# Auto-Continue (stop hook forces task completion)
# Max cycles before allowing stop regardless of completion
# MAX_CONTINUE_CYCLES=100

###############################################################################
# SUPERVISOR AGENT CONFIGURATION
# The supervisor is a separate Claude Code instance that validates task completion
###############################################################################

# Supervisor evaluation limits
# SUPERVISOR_MAX_LOOPS=20              # Max evaluation rounds before forcing stop
# SUPERVISOR_TIMEOUT=3600              # Timeout for agent curl -> supervisor /evaluate AND supervisor's Claude eval (seconds)
# STOP_HOOK_EXTRA_SEC=1200             # Added to SUPERVISOR_TIMEOUT for the agent Stop hook command timeout (Langfuse headroom)
# SUPERVISOR_AUTONOMY_APPEND=true      # If true, agent stop hook appends a short "keep working, user absent" nudge to NOT_COMPLETE feedback

# Supervisor's own Langfuse tracing (optional - separate project for supervisor traces)
# SUPERVISOR_TRACE_TO_LANGFUSE=false
# SUPERVISOR_LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# SUPERVISOR_LANGFUSE_SECRET_KEY=sk-lf-xxx
# SUPERVISOR_LANGFUSE_PROJECT=claude-supervisor

# Note: Agent's Langfuse credentials (LANGFUSE_*) are automatically passed
# to supervisor so it can review agent traces if needed

###############################################################################
# LLM HOST OVERRIDES (all default to LLM_HOST above)
###############################################################################

# Supervisor LLM (if running on different GPU/machine)
# SUPERVISOR_LLM_HOST=other-gpu.local
# SUPERVISOR_LLM_PORT=11234

# Vision LLM (if running on different GPU/machine)
# VISION_HOST=other-gpu.local
# VISION_PORT=11234

###############################################################################
# MULTI-INSTANCE (run multiple agents in parallel)
###############################################################################

# Instance name - auto-generated if not set (e.g., agent-a1b2c3d4)
# INSTANCE_NAME=worker1

# Port prefix (single digit prepended to container port)
# Auto-generated 2-5 based on instance name hash (max 5 since 68000 > 65535)
# Example: PORT_PREFIX=2 → 23000, 25000, 28000, 28080
# PORT_PREFIX=2
