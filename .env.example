# LLM Backend (LM Studio, Ollama, vLLM, etc.)
# Set to IP of machine running LM Studio (e.g., 192.168.1.100)
# Use 127.0.0.1 only if LM Studio runs on the same machine as Docker
LLM_HOST=<your-lm-studio-ip>
LLM_PORT=11234
LLM_AUTH_TOKEN=lmstudio
LLM_MODEL=<your-model-name>

# Vision Model (optional - for screenshot/image analysis)
# Uses same host/port as LLM backend, just different model
VISION_MODEL=qwen/qwen3-vl-4b

# Whoogle Search Service (optional - leave empty to disable)
# WHOOGLE_URL=http://<your-whoogle-ip>:5000

# Resource Limits
MEMORY_LIMIT=16G
MEMORY_RESERVATION=2G

# Workspace
WORKSPACE_NAME=default
# Base path for workspaces (use internal drive on macOS to avoid exFAT issues)
# Leave commented to use ./workspaces/ relative to project
# WORKSPACE_BASE=/Users/yourusername/claude-workspaces
