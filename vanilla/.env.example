# Vanilla Claude Code Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# REQUIRED
# ===================

# Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ===================
# OPTIONAL
# ===================

# Model to use (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ===================
# LANGFUSE TRACING (optional)
# ===================

# Enable tracing (default: false)
# TRACE_TO_LANGFUSE=true

# Langfuse server URL (use host.docker.internal for local Langfuse)
# LANGFUSE_HOST=http://host.docker.internal:3000

# Langfuse API keys (get from Langfuse project settings)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# Project name in Langfuse
# LANGFUSE_PROJECT=claude-vanilla

# Enable debug logging for tracing
# LANGFUSE_DEBUG=false
